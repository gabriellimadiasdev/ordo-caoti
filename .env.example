# Backend publico / dominio
NODE_ENV=production
PORT=3000
FRONTEND_PUBLIC_BASE_URL=https://www.your-domain.com/frontend/html
ORDO_API_BASE_URL=https://api.your-domain.com
API_PUBLIC_BASE_URL=https://api.your-domain.com
CORS_ALLOWED_ORIGINS=https://www.your-domain.com,https://your-domain.com
CANONICAL_HOST=www.your-domain.com
ADDITIONAL_PUBLIC_DOMAINS=your-domain.com

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=YOUR_MERCADO_PAGO_ACCESS_TOKEN
MERCADO_PAGO_WEBHOOK_SECRET=YOUR_MERCADO_PAGO_WEBHOOK_SECRET

# PostgreSQL e seguranca (use valores longos, aleatorios e exclusivos por ambiente)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
JWT_SECRET=GENERATE_A_64_CHARACTER_RANDOM_SECRET
COOKIE_SECRET=GENERATE_A_DIFFERENT_64_CHARACTER_RANDOM_SECRET

# Google (Meet + Drive + Classroom)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REFRESH_TOKEN=YOUR_GOOGLE_REFRESH_TOKEN
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_DRIVE_SHARED_FOLDER_ID=
GOOGLE_BOOKS_API_KEY=YOUR_GOOGLE_BOOKS_API_KEY

# AWS S3 privado para anexos. Prefira uma IAM Role no provedor a chaves estaticas.
AWS_REGION=sa-east-1
AWS_S3_BUCKET=your-private-uploads-bucket
AWS_S3_PREFIX=uploads
AWS_S3_PUBLIC_BASE_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Daily.co. A chave fica somente no backend.
DAILY_API_KEY=YOUR_DAILY_API_KEY
DAILY_DOMAIN=https://your-team.daily.co

# Bootstrap governanca
BOOTSTRAP_ADMIN_CAIO_PASSWORD=SET_A_LONG_UNIQUE_PASSWORD_IN_THE_DEPLOYMENT_SECRET_MANAGER
BOOTSTRAP_ADMIN_CAIO_EMAIL=contatocaiozanoni@gmail.com
BOOTSTRAP_ADMIN_DAYENNE_PASSWORD=SET_A_LONG_UNIQUE_PASSWORD_IN_THE_DEPLOYMENT_SECRET_MANAGER
BOOTSTRAP_ADMIN_DAYENNE_EMAIL=dayeekennedy@gmail.com
BOOTSTRAP_TI_PASSWORD=SET_A_LONG_UNIQUE_PASSWORD_IN_THE_DEPLOYMENT_SECRET_MANAGER
BOOTSTRAP_TI_EMAIL=g.lima.rocha90@gmail.com
BOOTSTRAP_FOUNDERS_ENABLED=false
ADMIN_AREA_SHARED_PASSCODE=SET_A_LONG_UNIQUE_BOOTSTRAP_PASSCODE

# Opcional
WHATSAPP_WEBHOOK_URL=
APP_PREFERENCES_VERSION=2026.04
TERMO_PRIVACIDADE_VERSAO=2026.04
PG_DUMP_BIN=pg_dump
